# PostgreSQL (platform-standard names — injected by Heroku/Railway/Docker)
POSTGRES_USER=ejagriti
POSTGRES_PASSWORD=ejagriti_secret
POSTGRES_DB=ejagriti

# Full connection URLs (platform-standard)
DATABASE_URL=postgresql://ejagriti:ejagriti_secret@postgres:5432/ejagriti
# Optional: point to a read replica for SELECT queries
REPLICA_DATABASE_URL=

# Redis (platform-standard)
REDIS_URL=redis://redis:6379/0

# Flask (framework-standard)
SECRET_KEY=change-me-in-production-use-a-random-64-char-string

# ── eJagriti custom vars ─────────────────────────────────────────────────────
# All custom vars are prefixed EJAGRITI_ to avoid conflicts with host env vars

# API Service
EJAGRITI_RATE_LIMIT_PER_MINUTE=100
EJAGRITI_CACHE_TTL_SECONDS=3600
EJAGRITI_SA_POOL_SIZE=5
EJAGRITI_SA_MAX_OVERFLOW=10

# Ingestion Service
EJAGRITI_BASE_URL=https://e-jagriti.gov.in
EJAGRITI_SEARCH_KEYWORD=samsung
EJAGRITI_DAILY_CALL_BUDGET=3500
EJAGRITI_MAX_CONCURRENT_REQUESTS=2
EJAGRITI_MAX_RETRIES=5
EJAGRITI_FETCH_CASES_FROM_DATE=2015-01-01

# Set to "true" to run one full batch and exit (for Cloud Run / ECS Scheduled Tasks)
EJAGRITI_RUN_ONCE=true

# Set to "true" to fetch data but skip all DB writes (for smoke testing)
EJAGRITI_DRY_RUN=true

# PDF storage (leave blank to discard PDFs; set one of these)
EJAGRITI_PDF_STORAGE_DIR=
AWS_S3_BUCKET=

# Logging
EJAGRITI_LOG_LEVEL=INFO
# Directory for daily-rotating log files (relative to ingestion/ or absolute)
EJAGRITI_LOG_DIR=logs
