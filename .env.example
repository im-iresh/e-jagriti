# PostgreSQL
POSTGRES_USER=ejagriti
POSTGRES_PASSWORD=ejagriti_secret
POSTGRES_DB=ejagriti

# Full connection URLs
DATABASE_URL=postgresql://ejagriti:ejagriti_secret@postgres:5432/ejagriti
# Optional: point to a read replica for SELECT queries
REPLICA_DATABASE_URL=

# Redis
REDIS_URL=redis://redis:6379/0

# API Service
SECRET_KEY=change-me-in-production-use-a-random-64-char-string
RATE_LIMIT_PER_MINUTE=100
CACHE_TTL_SECONDS=3600

# Ingestion Service
EJAGRITI_BASE_URL=https://e-jagriti.gov.in
SEARCH_KEYWORD=samsung
DAILY_CALL_BUDGET=3500
MAX_CONCURRENT_REQUESTS=2
MAX_RETRIES=5

# Set to "true" to run one full batch and exit (for Cloud Run / ECS Scheduled Tasks)
RUN_ONCE=false

# Set to "true" to fetch data but skip all DB writes (for smoke testing)
DRY_RUN=false

LOG_LEVEL=INFO
